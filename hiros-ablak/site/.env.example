# Copy to .env.local for local development.
# Set the same values in Vercel → Project Settings → Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional analytics (loaded according to cookie consent)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=your_clarity_project_id

# Rackhost SMTP (SSL, port 465)
SMTP_HOST=mail.hirosablak.hu
SMTP_PORT=465
SMTP_USER=teszt@hirosablak.hu
SMTP_PASS=your_mailbox_password

# Outgoing From must be an authenticated mailbox on mail.hirosablak.hu
MAIL_FROM=teszt@hirosablak.hu
MAIL_TO=hirosablak@hirosablak.hu
