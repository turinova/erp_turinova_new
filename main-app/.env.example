# Copy to .env.local (not committed). See README / docs.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Foot counter — MJPEG from Raspberry Pi (server-side proxy).
# Example Tailscale: http://100.x.x.x:8000/stream.mjpg
# Must be reachable from the machine running next start (not from the browser).
FOOTCOUNTER_MJPEG_URL=

# Optional: browser loads stream directly (HTTPS tunnel URL). Use when Next cannot proxy long MJPEG.
# NEXT_PUBLIC_FOOTCOUNTER_STREAM_URL=https://footcounter.example.com/stream.mjpg

# Pi → Supabase sync (POST /api/footcounter/sync). Generate a long random secret; same value on Pi FOOTCOUNTER_SYNC_SECRET.
# FOOTCOUNTER_SYNC_SECRET=

# Dashboard RPC default device (must match Pi FOOTCOUNTER_DEVICE_SLUG, usually "default").
# FOOTCOUNTER_STATS_DEVICE_SLUG=default

# Server-side only (not NEXT_PUBLIC): required for sync API and stats RPC.
# SUPABASE_SERVICE_ROLE_KEY=
